# PDF input
INPUT_PDF="Pages from SADDLEBACK VILLAGE RAMADAS - Sealed Drawings 8-22-25.pdf"

# true = rasterize PDF to high-DPI PNGs per page (better for small text/dimensions); false = send PDF bytes
PDF_AS_IMAGES="true"
# Rendering resolution (72 = screen; 300–600 = print/detail; capped by PDF_IMAGE_MAX_SIDE_PX for API limits)
PDF_IMAGE_DPI="400"
# Longest edge in pixels after render (if exceeded, zoom is reduced uniformly). Try 3072–8192 per model limits.
PDF_IMAGE_MAX_SIDE_PX="4096"
# Optional: only first N pages (empty = all pages)
# PDF_MAX_PAGES=""

# Parse SCALE lines from PDF text (e.g. 1/4" = 1'), inject into Gemini prompt + meta + Excel
# EXTRACT_DRAWING_SCALES="true"
# OUTPUT_DRAWING_SCALES_JSON="drawing_scales.json"

# PDF text for scale parsing: pymupdf (local) | document_ai (Google Cloud) | auto (try Document AI if configured)
# PDF_TEXT_ENGINE="auto"
# --- Google Document AI (service account JSON — NOT the Gemini API key) ---
# Create an OCR or Form Parser processor in Google Cloud Console; grant the service account "Document AI API User".
# GOOGLE_APPLICATION_CREDENTIALS="/absolute/path/to/service-account.json"
# DOCUMENT_AI_PROJECT_ID="your-gcp-project-id"
# DOCUMENT_AI_LOCATION="us"
# DOCUMENT_AI_PROCESSOR_ID="your-processor-id"
# DOCUMENT_AI_TIMEOUT_SEC="300"

# Output JSON (fabrication-grade takeoff)
OUTPUT_JSON="takeoff_output.json"

# Optional: Gemini spatial pass — proposes view/member bounding boxes (JSON), then injects hints into the main takeoff prompt.
# Uses the Gemini API (multimodal), NOT YOLO/CNN. Rasterizes the PDF once for this pass; pair with PDF_AS_IMAGES=true for image-based takeoff.
# GEMINI_SPATIAL_DETECTION="false"
#
# Optional: ONNX YOLO (train your own model; pip install onnxruntime). Merged with Gemini spatial hints when both set.
# YOLO_ONNX_MODEL="/absolute/path/to/best.onnx"
# YOLO_CLASS_NAMES="beam,column,plate"
# YOLO_CONF_THRESHOLD="0.25"
# YOLO_IOU_THRESHOLD="0.45"
# LEARNED_DETECTION_JSON="/path/to/custom_detections.json"

# Steel weight post-fill: AISC nominal lb/ft × length for W/M/S/HP/MC when weight is null (see steel_weight_enrichment.py)
# STEEL_WEIGHT_ENRICH_AUTO="true"
# WEIGHT_OVERRIDE_CSV="/path/to/weights.csv"
# Optional: align takeoff rows to a shop Project-1 BOM before nominal AISC / CSV (integrated_pipeline)
# ALIGN_REFERENCE_PROJECT1_BOM="/path/to/Project-1 - BOM.xlsx"
# ALIGN_REFERENCE_TOLERANCE_INCHES="6"
# ALIGN_FILL_PIECEMARKS="false"   # optional; use --align-fill-piecemarks on CLI
# Overwrite weights during steel enrichment (CSV + nominal both respect this in full_pipeline)
# OVERWRITE_STEEL_WEIGHT="false"
# OUTPUT_DETECTIONS_JSON="detections_output.json"
# Faster/cheaper model for box proposal only (defaults to GEMINI_MODEL if unset):
# GEMINI_DETECTION_MODEL="gemini-2.5-flash"
# GEMINI_DETECTION_PROMPT_PATH="prompts/spatial_detection.txt"
# GEMINI_DETECTION_MAX_OUTPUT_TOKENS="8192"

# JSON → Excel (python -m saddleback_pipeline.json_to_xlsx)
# INPUT_JSON="takeoff_output.json"
# OUTPUT_XLSX="takeoff_output.xlsx"

# BOM accuracy vs true Material Summary (python -m saddleback_pipeline.bom_accuracy)
# REFERENCE_BOM_XLSX="26-LQ-094_SADDLEBACK VILLAGE_Material Summary.xlsx"
# Optional: length tolerance (inches) for relaxed key F1 (also: --relaxed-inches 2)
# BOM_RELAXED_LENGTH_INCHES="2"

# Validation suite: BOM + geometry report (no Gemini)
# python -m saddleback_pipeline.validation_suite
# python -m saddleback_pipeline.validation_suite --json takeoff_output_spatial.json
# GEOMETRY_REPORT_JSON="geometry_report.json"
# VALIDATION_REPORT_JSON="validation_report.json"

# Vector / raster line extraction (python -m saddleback_pipeline.pdf_geometry)
# GEOMETRY_PAGE_INDEX="0"

# Geometry ↔ takeoff fusion (needs view boxes from detections_output.json)
# DETECTIONS_JSON="detections_output.json"
# FUSION_REPORT_JSON="fusion_report.json"
# python -m saddleback_pipeline.geometry_fusion

# Align material_summary keys to reference xlsx (improves strict BOM key F1 when lengths are close)
# RECONCILE_TOLERANCE_INCHES="12"
# OUTPUT_JSON_RECONCILED="takeoff_output_reconciled.json"
# python -m saddleback_pipeline.material_summary_reconcile

# --- One command: best-accuracy takeoff + reconcile + Excel (same XLSX layout as json_to_xlsx) ---
# Uses: PDF_AS_IMAGES, GEMINI_SPATIAL_DETECTION, reconcile, then writes OUTPUT_XLSX from reconciled JSON.
# python -m saddleback_pipeline.full_pipeline
# python -m saddleback_pipeline.full_pipeline --no-spatial   # skip detection pass
# OUTPUT_XLSX="takeoff_output.xlsx"
# OUTPUT_JSON_RECONCILED="takeoff_output_reconciled.json"

# --- Multi-PDF integrated orchestration (merge + optional reconcile + Project-1 BOM + validation_suite) ---
# python -m saddleback_pipeline.integrated_pipeline --help
# Example:
# python -m saddleback_pipeline.integrated_pipeline --pdfs "a.pdf" "b.pdf" --out-dir integrated_output \\
#   --merged-json integrated_output/merged.json --project1-bom-xlsx integrated_output/merged_bom.xlsx \\
#   --reference-material-xlsx "26-LQ-094_SADDLEBACK VILLAGE_Material Summary.xlsx" --run-validation
# Foundation / civil sheets (stem names without .pdf): --foundation-sheet-stems S111

# Benchmark multiple Gemini vision models (API; not Cursor chat models):
# python -m saddleback_pipeline.benchmark_models
# python -m saddleback_pipeline.benchmark_models --evaluate-only   # rescore benchmark_runs/* only

# Gemini API (use Gemini 3.1 Pro Preview for document + vision reasoning)
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-3.1-pro-preview"
# Seconds (default 1800 = 30 min). The client converts this to milliseconds internally.
GEMINI_HTTP_TIMEOUT_SEC="1800"
# Max tokens for the JSON response (large entity-expanded outputs need headroom).
GEMINI_MAX_OUTPUT_TOKENS="65536"
# true = streaming API (recommended for long PDFs: progress in terminal; helps avoid idle read timeouts)
GEMINI_STREAM="true"

# Prompt file (edit prompts/structural_takeoff.txt to change rules)
PROMPT_PATH="prompts/structural_takeoff.txt"

# Optional: CSV describing required schema fields (appended to prompt)
SCHEMA_CSV="schema_required.csv"
